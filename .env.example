# ============================================================
#  HOW TO USE:
#  1. Rename this file from ".env.example" to ".env"
#  2. Replace "your_api_key_here" below with your actual key
#  3. Get your API key at https://console.anthropic.com/
# ============================================================

ANTHROPIC_API_KEY=your_api_key_here

# Optional: Supabase Database Integration (for persistent memory)
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_anon_key
