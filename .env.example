# ============================================================
#  HOW TO USE:
#  1. Rename this file from ".env.example" to ".env"
#  2. Fill in the values below with your actual keys
# ============================================================

# AI Provider — choose which AI to use: "anthropic" or "openai"
AI_PROVIDER=anthropic

# Anthropic API Key — get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI API Key — get yours at https://platform.openai.com/
OPENAI_API_KEY=your_api_key_here
# OpenAI model (must support chat completions + vision)
# Examples: gpt-4o-2024-08-06, gpt-5-mini, gpt-5.2, gpt-5.4
OPENAI_MODEL=gpt-5.4

# Optional: Supabase Database Integration (for persistent memory)
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_anon_key
